# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your project's public URL
SUPABASE_URL=https://your-project-id.supabase.co

# anon/public key — safe to expose to the frontend
SUPABASE_ANON_KEY=your-anon-key-here

# service_role key — NEVER expose this. Backend only. Used for admin operations (seeding).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL of the React frontend (used to allow cross-origin requests)
FRONTEND_URL=http://localhost:5173
